# =============================================================
# VIRTUAL HOMESCHOOL LMS - Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# =============================================================

# ----------------------
# DATABASE
# ----------------------
# PostgreSQL connection string (Neon / Supabase / Railway recommended)
DATABASE_URL="postgresql://username:password@host:5432/lms_db?sslmode=require"

# ----------------------
# NEXTAUTH
# ----------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"
# In production: NEXTAUTH_URL="https://your-domain.vercel.app"

# ----------------------
# CLOUDINARY (File Storage)
# ----------------------
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"

# ----------------------
# OPENAI (LLM Features)
# ----------------------
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"

# ----------------------
# APP CONFIG
# ----------------------
NEXT_PUBLIC_APP_NAME="EduVerse LMS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ----------------------
# RATE LIMITING
# ----------------------
# Redis URL (optional - Upstash Redis recommended for Vercel)
# If not set, in-memory rate limiting is used (not suitable for multiple instances)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"
